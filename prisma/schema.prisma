generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ticket {
  id        String   @id @default(cuid())
  number    Int      @unique
  status    String   @default("waiting") // waiting | serving | done
  createdAt DateTime @default(now())
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model Counter {
  id      String @id @default(cuid())
  current Int    @default(1)
}